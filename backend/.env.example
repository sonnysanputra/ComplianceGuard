# Copy this file to ".env" and fill in the values.

# ---- LLM (any OpenAI-compatible provider) ----
# Default: local Ollama, no key required.
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
CHAT_MODEL=qwen2.5:7b
EMBED_MODEL=nomic-embed-text

# To deploy against OpenAI instead, comment out the block above and use:
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_API_KEY=sk-your-openai-key
#   CHAT_MODEL=gpt-4o-mini
#   EMBED_MODEL=text-embedding-3-small
#
# If chat and embeddings come from different providers (e.g. Groq chat with no
# embeddings API), set these to override just the embedding endpoint:
#   EMBED_BASE_URL=https://api.openai.com/v1
#   EMBED_API_KEY=sk-your-openai-key

# Supabase -- from your project's Settings > API page.
# Use the SERVICE ROLE key (backend only; keep it secret -- .env is gitignored).
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_KEY=your-service-role-key
